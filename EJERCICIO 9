// PROCESO PARA SACAR EL 15% DE DESCUENTO EN UNA COMPRA
PROCESO PROCEDIMIENTOPARASACAREL15%DEDESCUENTOENUNACOMPRA
 ESCRIBIR "BIENVENIDO, TE AYUDARE A SACAR EL 15% DE DESCUENTO EN TU COMPRA"
 ESCRIBIR "DIGITE EL VALOR TOTAL"
 LEER VALORTOTAL
 RESULTADO = VALORTOTAL * 15 / 100
 ESCRIBIR "SI TU VALOR TOTAL ES DE ", VALORTOTAL, ", ENTONCES CON EL DESCUENTO DEL 15% TE TOCARA PAGAR ", RESULTADO
FINPROCESO
