//PROCESO PARA CALCULAR SUMA, RESTA, MULTIPLICACION Y DIVISION DE LOS DOS MISMOS NUMEROS
PROCESO SUMA,RESTA,MULTIPLICACIONYDIVISION
 ESCRIBIR "BIENVENIDO AL PROGRAMA QUE SUMA, RESTA, MULTIPLICA Y DIVIDE LOS DOS MISMO NUMEROS"
 ESCRIBIR "DIGITE NUM1"
 LEER NUM1
 ESCRIBIR "DIGITE NUM2"
 LEER NUM2
 RESULTADOSUMA = NUM1 + NUM2
 RESULTADORESTA = NUM1 - NUM2
 RESULTADOMULTIPLICACION = NUM1 * NUM2
 RESULTADODIVISION = NUM1 / NUM2
 ESCRIBIR "SI EL PRIMER NUMERO ES ", NUM1, " Y EL SEGUNDO ", NUM2, ", ENTONCES EL RESULTADO DE LA SUMA ES ", RESULTADOSUMA, ", EL DE LA RESTA ES ", RESULTADORESTA, ", EL DE LA MULTIPLICACION ES ", RESULTADOMULTIPLICACION, " Y EL DE LA DIVISION ES ", RESULTADODIVISION
FINPROCESO
