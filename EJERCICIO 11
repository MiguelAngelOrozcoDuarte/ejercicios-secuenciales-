//PROCESO PARA CALCULAR A QUE DISTANCIA ESTAN UN NUMERO DEL OTRO
Proceso PARACALCULARAQUEDISTANCIAESTANUNNUMERODELOTRO
 ESCRIBIR "BIENVENIDO AL PROGRAMA QUE TE AYUDARA A QUE DISTANCIA ESTA UN NUMERO DEL OTRO"
 ESCRIBIR "DIGITE EL PRIMER NUMERO"
 LEER NUM1
 ESCRIBIR "DIGITE EL SEGUNDO NUMERO"
 LEER NUM2
 DISTANCIA = NUM1 - NUM2
 SI DISTANCIA < 0 ENTONCES //Si la distancia es negativa, la vuelvo positiva
  DISTANCIA = DISTANCIA * (-1) //Si ya es positiva, no hago nada
 FINSI
 ESCRIBIR "LA DISTANCIA QUE TIENE EL NUMERO ", NUM1, " DEL NUMERO ", NUM2 , ", ES DE ", DISTANCIA
FinProceso
