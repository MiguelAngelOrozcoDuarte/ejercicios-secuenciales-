//PROCESO PARA CALCULAR A QUE DISTANCIA ESTAN UN NUMERO DEL OTRO
Proceso PARACALCULARAQUEDISTANCIAESTANUNNUMERODELOTRO
 ESCRIBIR "BIENVENIDO AL PROGRAMA QUE TE AYUDARA A QUE DISTANCIA ESTA UN NUMERO DEL OTRO"
 ESCRIBIR "DIGITE EL PRIMER NUMERO"
 LEER NUM1
 ESCRIBIR "DIGITE NUM 2"
 LEER NUM2
 DISTANCIA = NUM1 - NUM2
 SI DISTANCIA < 0 ENTONCES 
  DISTANCIA = DISTANCIA * (-1)
 FINSI
 ESCRIBIR "LA DISTANCIA QUE TIENE LOS NUMEROS ES DE ", DISTANCIA
FinProceso
