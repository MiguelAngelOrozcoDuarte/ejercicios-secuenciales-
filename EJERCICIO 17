//PROCESO PARA SABER CUAL SERA LA HORA DE LLEGADA DE UN CICLISTA DESDE UN PUNTO HASTA EL OTRO
PROCESO SABERCUANTOTIEMPOSEDEMORARAUNCICLISTAENLLEGARDESDEUNPUNTOHASTAOTRO
 DEFINIR HH,MM,SS,T,TOTAL,LLEGADA_H,LLEGADA_M,LLEGADA_S COMO ENTERO
 ESCRIBIR "HORA DE SALIDA(HH MM SS)"
 LEER HH,MM,SS
 ESCRIBIR "TIEMPO DE VIAJE EN SEGUNDOS"
 LEER T
 TOTAL = HH * 3600 + MM * 60 + SS + T
 LLEGADA_H = TOTAL / 3600
 LLEGADA_M = (TOTAL MOD 3600) / 60
 LLEGADA_S = TOTAL MOD 60
 ESCRIBIR "HORA DE LLEGADA: ", LLEGADA_H, ": ", LLEGADA_M, ": ", LLEGADA_S
FINPROCESO
