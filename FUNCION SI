Algoritmo EDAD
	// REALIZAR UN PROGRMA QUE CAPTURE LA EDAD DE UNA PERSONA Y DETERMINAR SI ES MAYOR DE EDAD 
	Escribir "PROGRAMA QUE DETERMINA LA MAYORIA DE EDAD DE UNA PERSONA"
	Escribir "BUENAS"
	Escribir "DIGITE SU NOMBRE"
	LEER NOMBRE
	ESCRIBIR "DIGITE EDAD: "
	LEER EDAD1
	 SI EDAD1 >= 18 Entonces
		 Escribir NOMBRE, " ES MAYOR DE EDAD"
	 SiNo
		 Escribir NOMBRE, " ES MENOR DE EDAD"
	 FinSi
FinAlgoritmo
