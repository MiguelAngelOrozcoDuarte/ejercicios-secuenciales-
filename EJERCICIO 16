//PROCESO PARA SABER EN CUANTO TIEMPO ALCANZARA UN VEHICULO A OTRO
Proceso PARASABERENCUANTOTIEMPOALCANZARAUNVEHICULOAOTRO
 ESCRIBIR "INGRESE LA DISTANCIA ENTRE LOS DOS VEHICULOS"
 LEER D
 ESCRIBIR "VELOCIDAD DEL VEHICULO 1"
 LEER V1
 ESCRIBIR "VELOCIDAD DEL VEHICULO 2"
 LEER V2
 TIEMPO = D / (V1 - V2)
 RESPUESTA = TIEMPO * 60
 ESCRIBIR "EL TIEMPO QUE SE DEMORARA EL VEHICULO 1 EN ALCANZAR AL VEHICULO 2 EN MINUTOS ES: ", RESPUESTA
FinProceso
