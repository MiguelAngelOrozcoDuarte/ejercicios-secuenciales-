// PROCESO QUE PASA DE GRADOS FAHRENHEIT A GRADOS CELSIUS
PROCESO DEGRADOSFAHRENHEITACELSIUS
 ESCRIBIR "BIENVENIDO AL PROGRAMA QUE PASA DE GRADOS FAHRENHEIT A GRADOS CELSIUS"
 ESCRIBIR "ESCRIBA EL GRADO EN FAHRENHEIT"
 LEER FAHRENHEIT
 RESULTADO = (FAHRENHEIT - 32) * 5 / 9 
