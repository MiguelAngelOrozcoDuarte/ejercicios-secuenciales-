//PROCESO PARA SABER CUAL EL ES EL RESULTADO OBTENIDOPOR EL ESTUDIANTE
PROCESO SABERCUALESELRESULTADOQUEOBTUVOELESTUDIANTE
 ESCRIBIR "DIGITE LA CANTIDAD DE RESPUESTAS CORRECTAS"
 LEER CORRECTAS
 ESCRIBIR "DIGITE LA CANTIDAD DE RESPUESTAS INCORRECTAS"
 LEER INCORRECTAS
 ESCRIBIR "DIGITE LA CANTIDAD DE RESPUESTAS EN BLANCO"
 LEER BLANCO
 NOTA = (CORRECTAS * 5) + (INCORRECTAS * -1) + (BLANCO * 0)
 ESCRIBIR "SU NOTA FINAL ES: ", NOTA
FINPROCESO
