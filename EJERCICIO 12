//PROCESO PARA CALCULAR LA DISTANCIA ENTRE DOS COORDENADAS
PROCESO DISTANCIACOORDENADAS
 ESCRIBIR "DIGITE X1"
 LEER X1
 ESCRIBIR "DIGITE Y1"
 LEER Y1
 ESCRIBIR "DIGITE X2"
 LEER X2
 ESCRIBIR "DIGITE Y2"
 LEER Y2
 DISTANCIA = ((X2-X1)^2 + (Y2-Y1)^2)
 ESCRIBIR "LA DISTANCIA ENTRE LOS PUNTOS ES DE: ", DISTANCIA
FINPROCESO
